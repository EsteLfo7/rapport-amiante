# .env.example (versionne, pour les collaborateurs)
GEMINI_API_KEY=your_gemini_api_key_here

# ---------------------------------------------------------------------------
# Mode de traitement des PDFs
# ---------------------------------------------------------------------------
# 'gemini' (defaut) : envoie le PDF complet a Gemini Flash (multimodal).
#                     Plus precis sur PDFs complexes (tableaux, layout non standard).
# 'rag'             : extraction texte via pdfplumber + chunking + post-traitement
#                     Gemini Flash Lite. Moins cher en tokens, ideal PDFs textuels.
RAG_MODE=gemini
