{
  "productName": "rapport-amiante",
  "version": "0.1.0",
  "identifier": "com.rapport-amiante.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
  "windows": [
    {
      "title": "Rapport Amiante",
      "width": 900,
      "height": 620,
      "minWidth": 720,
      "minHeight": 480,
      "resizable": true,
      "fullscreen": false,
      "dragDropEnabled": true

    }
  ],
  "security": {
    "csp": null
  }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": { "open": true }
  }
}
